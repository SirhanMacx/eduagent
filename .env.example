# Required: at least one LLM backend
ANTHROPIC_API_KEY=sk-ant-your-key-here
# OPENAI_API_KEY=sk-your-key-here

# Ollama base URL — used by AppConfig.ollama_base_url
# In Docker, use host.docker.internal to reach the host machine's Ollama
# OLLAMA_URL=http://host.docker.internal:11434

# Data directory — where databases and config are stored
# Defaults to eduagent_data/ (web DB) and ~/.eduagent/ (state DB)
# In Docker, set to /data (matches the VOLUME in Dockerfile)
# EDUAGENT_DATA_DIR=/data

# Required for Telegram bot (teacher)
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here

# Required for student Telegram bot (separate bot)
STUDENT_BOT_TOKEN=your-student-bot-token-here
